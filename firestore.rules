rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // دالة كتحقق واش نتا هو مول هاد الإيميل بالضبط
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email == "rrenglish66@gmail.com";
    }

    // 1. أي واحد مسجل كيقرا ويعدل غير البروفايل ديالو، والأدمن عندو الحق فكلشي
    match /users/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isSuperAdmin();
    }

    // 2. كوليكشن Learn: القراءة للجميع، والكتابة حصرياً للسوبر أدمن
    match /learn_lessons/{document=**} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // 3. كوليكشن Practice: القراءة للجميع، والكتابة حصرياً للسوبر أدمن
    match /practice_lessons/{document=**} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // 4. قاعدة عامة للأدمن باش يقدر يدخل لأي حاجة أخرى (بحال المجلدات اللي يالاه غتكريهوم)
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}