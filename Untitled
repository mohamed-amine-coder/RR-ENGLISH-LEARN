rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- وظائف مساعدة ---
    function isLoggedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isLoggedIn() && (
        request.auth.token.email == "rrenglish66@gmail.com" || 
        getUserData().role == "admin"
      );
    }

    // --- القواعد ---

    // 1. بيانات المستخدمين
    match /users/{userId} {
      allow read, write: if isLoggedIn() && (request.auth.uid == userId || isAdmin());
    }

    // 2. دروس التعلم (Learn)
    match /learn_lessons/{lessonId} {
      allow read: if isLoggedIn(); 
      allow write: if isAdmin();
    }

    // 3. تمارين التطبيق (Practice)
    match /practice_lessons/{lessonId} {
      allow read: if isLoggedIn(); 
      allow write: if isAdmin();
    }

    // 4. قاعدة احتياطية
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}